# IAMS Backend Environment Template
# Copy this file to .env and fill with real values before running.
# NEVER commit .env to source control — it is listed in .gitignore.

# ---------------------------------------------------------------------------
# Database (MariaDB/MySQL)
# ---------------------------------------------------------------------------
DATABASE_URL=mysql+pymysql://iams:REPLACE_WITH_DB_PASSWORD@mysql:3306/iams_db

# ---------------------------------------------------------------------------
# Secrets — change these before any deployment.
# Generate JWT_SECRET:  python -c "import secrets; print(secrets.token_hex(64))"
# Generate AES key:    python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# ---------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_LONG
AES_KEY_BASE64=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY

# ---------------------------------------------------------------------------
# CORS / Frontend origin
# ---------------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Flask environment
#   development → DEBUG=True, COOKIE_SECURE=false
#   production  → DEBUG=False, COOKIE_SECURE=true (requires HTTPS)
# ---------------------------------------------------------------------------
FLASK_ENV=development

# ---------------------------------------------------------------------------
# Cookie settings
#   development (HTTP localhost): COOKIE_SECURE=false   COOKIE_SAMESITE=Lax
#   production  (HTTPS):          COOKIE_SECURE=true    COOKIE_SAMESITE=Strict
# ---------------------------------------------------------------------------
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# ---------------------------------------------------------------------------
# Rate limiting
#   development: memory://
#   production:  redis://redis:6379/0
# ---------------------------------------------------------------------------
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URI=memory://

# ---------------------------------------------------------------------------
# Frontend port exposed by Docker Compose
# ---------------------------------------------------------------------------
FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# MariaDB admin credentials for Docker Compose (dev only)
# ---------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=REPLACE_WITH_ROOT_PASSWORD
MYSQL_DATABASE=iams_db
MYSQL_USER=iams
MYSQL_PASSWORD=REPLACE_WITH_USER_PASSWORD
