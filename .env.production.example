# IAMS Production Environment Template
# Copy to .env and fill with production secrets.
# WARNING: Never commit real .env files. They are in .gitignore.
#
# Rotate ALL secrets listed below before first production deployment.
# Secrets in the dev .env are demo-only and MUST NOT be reused.

# Database
DATABASE_URL=mysql+pymysql://iams:INSERT_PRODUCTION_PASSWORD@mysql:3306/iams_db
MYSQL_ROOT_PASSWORD=INSERT_PRODUCTION_ROOT_PASSWORD
MYSQL_DATABASE=iams_db
MYSQL_USER=iams
MYSQL_PASSWORD=INSERT_PRODUCTION_USER_PASSWORD

# Secrets — generate fresh for production:
# JWT_SECRET:  python -c "import secrets; print(secrets.token_hex(64))"
# AES_KEY:     python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET=INSERT_PRODUCTION_JWT_SECRET
AES_KEY_BASE64=INSERT_PRODUCTION_AES_KEY_BASE64

# Production CORS origin (use real frontend domain)
FRONTEND_ORIGIN=https://your-frontend-domain.example.com

# Production mode — DO NOT set to development
FLASK_ENV=production
COOKIE_SECURE=true
COOKIE_SAMESITE=Strict

# Rate limiting with Redis (shared across gunicorn workers)
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URI=redis://redis:6379/0

# Frontend port
FRONTEND_PORT=3000
